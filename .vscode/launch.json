{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AccountService (5020)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "prepare: AccountService",
      "program": "${workspaceFolder}/src/AccountService/bin/Debug/net10.0/AccountService.dll",
      "cwd": "${workspaceFolder}/src/AccountService",
      "args": [
        "--urls",
        "http://localhost:5020"
      ],
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5020"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger/index.html"
      }
    },
    {
      "name": "CustomerService (5019)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "prepare: CustomerService",
      "program": "${workspaceFolder}/src/CustomerService/bin/Debug/net10.0/CustomerService.dll",
      "cwd": "${workspaceFolder}/src/CustomerService",
      "args": [
        "--urls",
        "http://localhost:5019"
      ],
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5019"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger/index.html"
      }
    }
  ],
  "compounds": [
    {
      "name": "Start Account + Customer Services",
      "configurations": [
        "AccountService (5020)",
        "CustomerService (5019)"
      ],
      "stopAll": true
    }
  ]
}