{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "accountservice: kill stale process",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/src/AccountService/.vscode/kill-accountservice.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "accountservice: build",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/AccountService/AccountService.csproj"
      ],
      "problemMatcher": [
        "$msCompile"
      ]
    },
    {
      "label": "accountservice: prepare launch",
      "dependsOn": [
        "accountservice: clean environment",
        "accountservice: build",
        "accountservice: open swagger"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "accountservice: open swagger",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "Start-Job -ScriptBlock { $url = 'http://localhost:5020/swagger/index.html'; for ($i = 0; $i -lt 60; $i++) { $conn = Get-NetTCPConnection -LocalPort 5020 -State Listen -ErrorAction SilentlyContinue; if ($conn) { Start-Process $url; break }; Start-Sleep -Milliseconds 500 } } | Out-Null"
      ],
      "problemMatcher": []
    },
    {
      "label": "accountservice: clean environment",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "& '${workspaceFolder}/src/AccountService/.vscode/kill-accountservice.ps1'; for ($i = 0; $i -lt 20; $i++) { $inUse = Get-NetTCPConnection -LocalPort 5020 -State Listen -ErrorAction SilentlyContinue; if (-not $inUse) { break }; Start-Sleep -Milliseconds 250 }; sqllocaldb start mssqllocaldb | Out-Null"
      ],
      "problemMatcher": []
    },
    {
      "label": "accountservice: run clean",
      "type": "shell",
      "dependsOn": [
        "accountservice: prepare launch"
      ],
      "dependsOrder": "sequence",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "dotnet run --project \"${workspaceFolder}/src/AccountService/AccountService.csproj\""
      ],
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}

