{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "accountservice: launch",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "accountservice: prepare launch",
      "program": "${workspaceFolder}/src/AccountService/bin/Debug/net10.0/AccountService.dll",
      "cwd": "${workspaceFolder}/src/AccountService",
      "args": [
        "--urls",
        "http://localhost:5020"
      ],
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5020"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger/index.html"
      }
    },
    {
      "name": "AccountService: Attach (pick process)",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}

