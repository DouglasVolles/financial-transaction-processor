{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "customerservice: launch",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "customerservice: prepare launch",
      "program": "${workspaceFolder}/src/CustomerService/bin/Debug/net10.0/CustomerService.dll",
      "cwd": "${workspaceFolder}/src/CustomerService",
      "args": [
        "--urls",
        "http://localhost:5019"
      ],
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5019"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger/index.html"
      }
    },
    {
      "name": "CustomerService: Attach (pick process)",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}
